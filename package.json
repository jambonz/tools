{
  "name": "@jambonz/tools",
  "version": "0.1.2",
  "description": "Pre-built, reusable tools for jambonz agent voice AI applications",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "keywords": [
    "jambonz",
    "voice",
    "ai",
    "tools",
    "agent",
    "llm",
    "function-calling"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jambonz/tools"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "eslint": "^9.27.0",
    "eslint-plugin-promise": "^7.2.1",
    "globals": "^16.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0"
  },
  "lint-staged": {
    "*.ts": "eslint --max-warnings 0"
  }
}
